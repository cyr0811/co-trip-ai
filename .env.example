# Public app URL used for local sharing and future callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI provider: openai or doubao.
AI_PROVIDER=doubao

# Doubao / Volcengine Ark OpenAI-compatible settings.
# DOUBAO_MODEL is your Ark inference endpoint ID or model identifier from the Ark console.
DOUBAO_API_KEY=
DOUBAO_MODEL=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# OpenAI settings, used when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
